# Cram backend — copy to .env and fill in. .env is gitignored (never commit a real key).

# Required: server-side Claude API key. The key lives ONLY here, never in a client.
ANTHROPIC_API_KEY=sk-ant-...

# Deployment environment: "dev" (default) or "prod". In prod the server REFUSES to
# start unless CRAM_SHARED_SECRET is set — the loopback-only fallback is dev-only and
# fails open behind a reverse proxy. Set this to prod for any non-local deploy.
# CRAM_ENV=dev

# Access control. When set, every /v1/generate request must send this value in the
# X-Cram-Secret header. When UNSET, the endpoint serves loopback (127.0.0.1) only —
# so set it before testing from a device or exposing the server beyond localhost.
# Required when CRAM_ENV=prod. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRAM_SHARED_SECRET=

# Optional overrides (defaults shown).
# CRAM_MODEL=claude-sonnet-4-6
# CRAM_MAX_FILES=20
# CRAM_MAX_FILE_BYTES=33554432      # 32 MiB per file
# CRAM_MAX_TOTAL_BYTES=33554432     # 32 MiB per request (Claude PDF inline limit)
# CRAM_MAX_FIELD_CHARS=4096         # cap on each text field (generate: subject_name/title/kind;
#                                   #   grade: prompt/model_answer/response/topic)
