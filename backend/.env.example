# Cram backend — copy to .env and fill in. .env is gitignored (never commit a real key).

# Required: server-side Claude API key. The key lives ONLY here, never in a client.
ANTHROPIC_API_KEY=sk-ant-...

# Deployment environment: "dev" (default) or "prod". In prod the server REFUSES to start
# unless Supabase JWT auth is configured (SUPABASE_JWKS_URL or SUPABASE_JWT_SECRET below) —
# the dev loopback fallback fails open behind a reverse proxy. Set prod for any non-local deploy.
# CRAM_ENV=dev

# DEPRECATED (v0.5): the X-Cram-Secret gate is superseded by Supabase JWT auth (see the
# v0.5 section below). No longer enforced; kept only so old .env files don't break.
# CRAM_SHARED_SECRET=

# Dev-only escape hatch. When set, AND only when no Supabase JWT auth is configured below,
# unauthenticated LOOPBACK requests are served as a fixed dev user — so you can run the API
# locally without a Supabase project. OFF by default (fails closed). Never set in prod: the
# startup guard refuses to boot if this is set with CRAM_ENV=prod.
# CRAM_ALLOW_DEV_FALLBACK=1

# Optional overrides (defaults shown).
# CRAM_MODEL=claude-sonnet-4-6
# CRAM_MAX_FILES=20
# CRAM_MAX_FILE_BYTES=33554432      # 32 MiB per file
# CRAM_MAX_TOTAL_BYTES=33554432     # 32 MiB per request (Claude PDF inline limit)
# CRAM_MAX_FIELD_CHARS=4096         # cap on each text field (generate: subject_name/title/kind;
#                                   #   grade: prompt/model_answer/response/topic)

# --- v0.5 persistence + auth (ADR 0007) ------------------------------------------------
# All optional until the Supabase project exists. With these unset the app still boots and
# /healthz reports "db": "not_configured". Fill them in to enable persistence (Phase 1+).

# Postgres connection strings from the Supabase dashboard (Project Settings -> Database).
# DATABASE_URL is the app runtime connection — use the TRANSACTION POOLER (port 6543).
# DATABASE_DIRECT_URL is the DIRECT connection (port 5432), used by Alembic migrations.
# Either postgresql:// or postgres:// is accepted; the driver is forced to psycopg.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# DATABASE_DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Supabase project URL (Project Settings -> API).
# SUPABASE_URL=https://<ref>.supabase.co

# JWT verification (Phase 2). Prefer the JWKS URL (asymmetric keys); else the shared secret.
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_SECRET=

# Service-role key — server-side ONLY, never ship to a client (Project Settings -> API).
# SUPABASE_SERVICE_ROLE_KEY=

# Private Storage bucket for uploaded source files (default: sources). Source uploads in
# /v1/generate are skipped (source persisted with empty storage_paths) unless SUPABASE_URL
# and SUPABASE_SERVICE_ROLE_KEY are both set.
# SUPABASE_STORAGE_BUCKET=sources

# --- v0.6 web dashboard CORS -----------------------------------------------------------
# Browser origins allowed to call the API cross-origin (the Next.js web client). Empty by
# default ⇒ CORS disabled, so iOS/native and same-origin clients are unaffected and a deploy
# stays locked down until you explicitly allow a web origin. Comma-separated EXACT origins
# (scheme://host[:port], no trailing slash). Set this in prod (e.g. Railway) before the live
# web app can call the backend. On Railway, enter the value RAW — no surrounding quotes.
# CRAM_CORS_ORIGINS=http://localhost:3000,https://<your-app>.vercel.app

# --- v0.5 Phase 4 pre-deploy hardening (ADR 0009) --------------------------------------
# All default to OFF (0) so dev/local is unaffected. In PROD all three are REQUIRED to be > 0
# (the startup guard refuses to boot otherwise) — an unmetered public LLM endpoint is an open
# wallet. See docs/SETUP.md -> Production deploy checklist.

# Per-caller request ceiling per minute across ALL /v1/* routes (0 = no limit). 60 is a
# generous default for an interactive client; over the limit returns 429 + Retry-After.
# CRAM_RATE_LIMIT_PER_MIN=60

# Anthropic spend cap: daily token ceilings (UTC day), token-based and exact from SDK usage.
# Per-user bounds one account; global bounds total blast-radius. 0 = no cap. Over budget the
# AI endpoints refuse with 429 BEFORE calling Claude. Tune to your budget.
# CRAM_USER_DAILY_TOKEN_CAP=200000
# CRAM_GLOBAL_DAILY_TOKEN_CAP=2000000

# Honour X-Forwarded-For for the rate-limit IP fallback ONLY when behind a trusted reverse
# proxy (otherwise a client can spoof the header). Leave off unless you terminate at a proxy.
# CRAM_TRUSTED_PROXY=1

# --- tests only ------------------------------------------------------------------------
# Disposable Postgres for the data-layer tests (pytest). Without it the DB-backed tests
# skip. Example (Docker): postgresql://postgres:pw@localhost:55432/postgres
# TEST_DATABASE_URL=
