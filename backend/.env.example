# Cram backend — copy to .env and fill in. .env is gitignored (never commit a real key).

# Required: server-side Claude API key. The key lives ONLY here, never in a client.
ANTHROPIC_API_KEY=sk-ant-...

# Deployment environment: "dev" (default) or "prod". In prod the server REFUSES to start
# unless Supabase JWT auth is configured (SUPABASE_JWKS_URL or SUPABASE_JWT_SECRET below) —
# the dev loopback fallback fails open behind a reverse proxy. Set prod for any non-local deploy.
# CRAM_ENV=dev

# DEPRECATED (v0.5): the X-Cram-Secret gate is superseded by Supabase JWT auth (see the
# v0.5 section below). No longer enforced; kept only so old .env files don't break.
# CRAM_SHARED_SECRET=

# Optional overrides (defaults shown).
# CRAM_MODEL=claude-sonnet-4-6
# CRAM_MAX_FILES=20
# CRAM_MAX_FILE_BYTES=33554432      # 32 MiB per file
# CRAM_MAX_TOTAL_BYTES=33554432     # 32 MiB per request (Claude PDF inline limit)
# CRAM_MAX_FIELD_CHARS=4096         # cap on each text field (generate: subject_name/title/kind;
#                                   #   grade: prompt/model_answer/response/topic)

# --- v0.5 persistence + auth (ADR 0007) ------------------------------------------------
# All optional until the Supabase project exists. With these unset the app still boots and
# /healthz reports "db": "not_configured". Fill them in to enable persistence (Phase 1+).

# Postgres connection strings from the Supabase dashboard (Project Settings -> Database).
# DATABASE_URL is the app runtime connection — use the TRANSACTION POOLER (port 6543).
# DATABASE_DIRECT_URL is the DIRECT connection (port 5432), used by Alembic migrations.
# Either postgresql:// or postgres:// is accepted; the driver is forced to psycopg.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# DATABASE_DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Supabase project URL (Project Settings -> API).
# SUPABASE_URL=https://<ref>.supabase.co

# JWT verification (Phase 2). Prefer the JWKS URL (asymmetric keys); else the shared secret.
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_SECRET=

# Service-role key — server-side ONLY, never ship to a client (Project Settings -> API).
# SUPABASE_SERVICE_ROLE_KEY=

# Private Storage bucket for uploaded source files (default: sources).
# SUPABASE_STORAGE_BUCKET=sources
