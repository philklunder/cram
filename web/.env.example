# Cram web dashboard — copy to .env.local and fill in. .env.local is gitignored.
# These are NEXT_PUBLIC_* because the browser client needs them. The Supabase anon key is
# public by design (Row-Level Security guards data); the SERVICE-ROLE key must NEVER appear here.

# Supabase project (same project as the iOS app). Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cram backend base URL. Defaults to the live Railway deployment when unset.
# Point this at http://127.0.0.1:8000 to develop against a local backend.
NEXT_PUBLIC_CRAM_BACKEND_URL=https://cram.up.railway.app
